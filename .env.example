# Copy to .env and fill in. Never commit real keys in this file.
# Finnhub (SPY, GLD, USO): https://finnhub.io/register
FINNHUB_API_KEY=

# Seconds between real CoinGecko calls for Bitcoin (default 90). Raise if you still see 429.
# COINGECKO_CACHE_TTL_SEC=120

# Scoring: absolute % move must exceed this to count as correct/incorrect (not neutral)
NEXT_PUBLIC_MOVE_THRESHOLD_PCT=0.5

# Optional — not used by the current app; reserved for future features
# OPENAI_API_KEY=
